# Application
PROJECT_NAME=MCP Agent Gateway
VERSION=0.1.0
DEBUG=false

# OpenTelemetry (zero-code via opentelemetry-instrument CLI)
# See: https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
OTEL_SERVICE_NAME=mcp_agent_gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp_proto_http
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0,deployment.environment=local
# OTEL_SDK_DISABLED=true  # uncomment to disable all tracing
# Caveat: production multi-worker (uvicorn --workers N) without gunicorn post_fork
# may lose worker spans. For real production, consider gunicorn + post_fork hook.

# Keycloak / OAuth 2.1 (RFC 9728)
OAUTH_ISSUER_URL=http://localhost:8080/realms/mcp-gateway
OAUTH_EXPECTED_AUDIENCE=http://localhost:8000/mcp/
OAUTH_JWKS_CACHE_TTL=3600

# Gateway
GATEWAY_BASE_URL=http://localhost:8000

# CORS — allowed browser origins (JSON list). Empty = none allowed.
# Example: ALLOWED_ORIGINS=["http://localhost:3000","https://app.example.com"]
ALLOWED_ORIGINS=[]

# Rate limiting (per-user sliding window, Redis-backed)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Redis / Valkey
REDIS_URL=redis://localhost:6379

# RFC 7591 Dynamic Client Registration (provider-agnostic)
# Keycloak example: http://localhost:8080/realms/mcp-gateway/clients-registrations/openid-connect
# Auth0 example:    https://your-tenant.auth0.com/oidc/register
DCR_REGISTRATION_ENDPOINT=http://localhost:8080/realms/mcp-gateway/clients-registrations/openid-connect
DCR_INITIAL_ACCESS_TOKEN=
CLIENT_REGISTRY_TTL=86400

# Google OAuth upstream
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Shared Drive refresh token from `gcloud` (see README). Leave empty to disable Drive.
GOOGLE_SHARED_REFRESH_TOKEN=

# Google Drive client tuning
GOOGLE_DRIVE_TIMEOUT=10.0
GOOGLE_DRIVE_MAX_CONNECTIONS=100
GOOGLE_DRIVE_MAX_KEEPALIVE=20
GOOGLE_DRIVE_MAX_RETRIES=3

# Slack upstream
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required whenever a shared Slack token is provisioned (tokens are Fernet-encrypted at rest).
SLACK_TOKEN_ENCRYPTION_KEY=
# Slack app signing secret — verifies inbound webhook HMAC (POST /webhooks/slack)
SLACK_SIGNING_SECRET=
SLACK_TIMEOUT=8.0
SLACK_MAX_RETRIES=3

# Shared Slack identity from a single-workspace app install (see README).
# Seeded into slack:token:shared at boot. Leave empty to disable Slack.
# xoxb- bot token (chat:write) — powers slack-send-message.
SLACK_SHARED_BOT_TOKEN=
# xoxp- user token (search:read) — required for slack-search-messages (search.messages rejects bot tokens).
SLACK_SHARED_USER_TOKEN=

# Async job queue — export storage dir (default: system temp /mcp-exports, 0700)
# EXPORT_DIR=/var/lib/mcp-gateway/exports
