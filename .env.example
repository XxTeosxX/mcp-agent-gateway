# Application
PROJECT_NAME=MCP Agent Gateway
VERSION=0.1.0
DEBUG=false

# OpenTelemetry (zero-code via opentelemetry-instrument CLI)
# See: https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
OTEL_SERVICE_NAME=mcp_agent_gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp_proto_http
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0,deployment.environment=local
# OTEL_SDK_DISABLED=true  # uncomment to disable all tracing
# Caveat: production multi-worker (uvicorn --workers N) without gunicorn post_fork
# may lose worker spans. For real production, consider gunicorn + post_fork hook.

# Keycloak / OAuth 2.1 (RFC 9728)
OAUTH_ISSUER_URL=http://localhost:8080/realms/mcp-gateway
OAUTH_EXPECTED_AUDIENCE=http://localhost:8000/mcp/
OAUTH_JWKS_CACHE_TTL=3600

# Gateway
GATEWAY_BASE_URL=http://localhost:8000

# Redis / Valkey
REDIS_URL=redis://localhost:6379

# RFC 7591 Dynamic Client Registration (provider-agnostic)
# Keycloak example: http://localhost:8080/realms/mcp-gateway/clients-registrations/openid-connect
# Auth0 example:    https://your-tenant.auth0.com/oidc/register
DCR_REGISTRATION_ENDPOINT=http://localhost:8080/realms/mcp-gateway/clients-registrations/openid-connect
DCR_INITIAL_ACCESS_TOKEN=
CLIENT_REGISTRY_TTL=86400

# Google OAuth upstream
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
